{
  "name": "jmandreslopez",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "yarn run start:dev",
    "start:dev": "ng serve --configuration dev",
    "start:uat": "ng serve --configuration uat",
    "start:prod": "ng serve --configuration prod",
    "build": "yarn run build:dev",
    "build:dev": "ng build --configuration dev",
    "build:uat": "ng build --configuration uat",
    "build:prod": "ng build --configuration prod",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "update:build:version": "node ./update.build.js ./version.json",
    "update:build:version:serve": "yarn run update:build:version serve",
    "update:build:version:patch": "yarn run update:build:version patch",
    "update:build:version:minor": "yarn run update:build:version minor",
    "update:build:version:major": "yarn run update:build:version major",
    "clean": "rm -rf",
    "clean:dist": "yarn run clean dist",
    "clean:vendors": "yarn run clean node_modules",
    "clean:install": "yarn run clean:vendors && yarn"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^6.1.0",
    "@angular/common": "^6.1.0",
    "@angular/compiler": "^6.1.0",
    "@angular/core": "^6.1.0",
    "@angular/forms": "^6.1.0",
    "@angular/http": "^6.1.0",
    "@angular/platform-browser": "^6.1.0",
    "@angular/platform-browser-dynamic": "^6.1.0",
    "@angular/router": "^6.1.0",
    "@fortawesome/fontawesome-free": "^5.2.0",
    "@ng-bootstrap/ng-bootstrap": "^3.0.0",
    "@ngx-loading-bar/router": "^2.1.2",
    "@ultimate/ngxerrors": "^1.4.0",
    "angular2-ladda": "^2.0.0",
    "angulartics2": "^6.2.0",
    "animate.css": "^3.7.0",
    "bootstrap": "^4.1.3",
    "core-js": "^2.5.4",
    "detect-browser": "^3.0.0",
    "file-saver": "^1.3.8",
    "he": "^1.1.1",
    "hover.css": "^2.3.2",
    "lodash": "^4.17.10",
    "moment": "^2.22.2",
    "ngx-cookie": "^4.0.2",
    "ngx-moment": "^3.1.0",
    "rxjs": "^6.0.0",
    "rxjs-compat": "^6.0.0",
    "zone.js": "~0.8.26"
