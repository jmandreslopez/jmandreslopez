{
  "name": "jmandreslopez",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "clean": "rm -rf",
    "clean:install": "yarn run clean node_modules dist && yarn",
    "build:site": "yarn run build:site:dev",
    "build:site:dev": "ng build site --configuration dev",
    "build:site:uat": "ng build site --configuration uat",
    "build:site:prod": "ng build site --configuration prod",
    "build:admin": "yarn run build:admin:dev",
    "build:admin:dev": "ng build admin --configuration dev",
    "build:admin:uat": "ng build admin --configuration uat",
    "build:admin:prod": "ng build admin --configuration prod",
    "serve:site": "yarn run update:site:serve && ng serve",
    "start:site": "yarn run start:site:dev",
    "start:site:dev": "yarn run serve:site site --configuration dev",
    "start:site:uat": "yarn run serve:site site --configuration uat",
    "start:site:prod": "yarn run serve:site site --configuration prod",
    "serve:admin": "yarn run update:site:serve && ng serve",
    "start:admin": "yarn run start:admin:dev",
    "start:admin:dev": "yarn run serve:admin admin --configuration dev",
    "start:admin:uat": "yarn run serve:admin admin --configuration uat",
    "start:admin:prod": "yarn run serve:admin admin --configuration prod",
    "update:site": "node ./update.build.js ./projects/site/app.json",
    "update:site:serve": "yarn run update:site serve",
    "update:site:patch": "yarn run update:site patch",
    "update:site:minor": "yarn run update:site minor",
    "update:site:major": "yarn run update:site major",
    "update:admin": "node ./update.build.js ./projects/admin/app.json",
    "update:admin:serve": "yarn run update:admin serve",
    "update:admin:patch": "yarn run update:admin patch",
    "update:admin:minor": "yarn run update:admin minor",
    "update:admin:major": "yarn run update:admin major"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^6.1.0",
    "@angular/common": "^6.1.0",
    "@angular/compiler": "^6.1.0",
    "@angular/core": "^6.1.0",
    "@angular/forms": "^6.1.0",
    "@angular/http": "^6.1.0",
    "@angular/platform-browser": "^6.1.0",
    "@angular/platform-browser-dynamic": "^6.1.0",
    "@angular/router": "^6.1.0",
    "@fortawesome/fontawesome-free": "^5.3.1",
    "@ng-bootstrap/ng-bootstrap": "^3.2.0",
    "@ngx-loading-bar/router": "^2.2.0",
    "@ultimate/ngxerrors": "^1.4.0",
    "angular2-ladda": "^2.0.0",
    "angulartics2": "^6.3.0",
    "animate.css": "^3.7.0",
    "bootstrap": "^4.1.3",
    "core-js": "^2.5.4",
    "detect-browser": "^3.0.0",
    "file-saver": "^1.3.8",
    "he": "^1.1.1",
    "lodash": "^4.17.11",
    "moment": "^2.22.2",
    "ngx-cookie": "^4.0.2",
    "ngx-moment": "^3.1.0",
    "rxjs": "^6.0.0",
    "rxjs-compat": "^6.0.0",
    "sweetalert2": "^7.26.0",
    "zone.js": "~0.8.26"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.8.2",
    "@angular/cli": "~6.2.2",
    "@angular/compiler-cli": "^6.1.0",
    "@angular/language-service": "^6.1.0",
    "@types/jasmine": "~2.8.6",
    "@types/jasminewd2": "~2.0.3",
    "@types/lodash": "^4.14.116",
    "@types/node": "~8.9.4",
    "codelyzer": "~4.2.1",
    "jasmine-core": "~2.99.1",
    "jasmine-spec-reporter": "~4.2.1",
    "karma": "~1.7.1",
    "karma-chrome-launcher": "~2.2.0",
    "karma-coverage-istanbul-reporter": "~2.0.0",
    "karma-jasmine": "~1.1.1",
    "karma-jasmine-html-reporter": "^0.2.2",
    "protractor": "~5.4.0",
    "ts-node": "~5.0.1",
    "tslint": "~5.9.1",
    "typescript": "~2.7.2"
  }
}
