{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "site": {
      "root": "projects/site/",
      "sourceRoot": "projects/site",
      "projectType": "application",
      "prefix": "ja",
      "schematics": {
        "@schematics/angular:component": {
          "styleext": "scss"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/site",
            "index": "projects/site/index.html",
            "main": "projects/site/main.ts",
            "polyfills": "projects/site/polyfills.ts",
            "tsConfig": "projects/site/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "library/assets",
                "output": "/"
              },
              {
                "glob": "**/*",
                "input": "projects/site/assets",
                "output": "/"
              }
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "projects/site",
                "projects/site/styles"
              ]
            },
            "styles": [
              "node_modules/@fortawesome/fontawesome-free/css/all.min.css",
              "node_modules/animate.css/animate.min.css",
              "node_modules/ladda/dist/ladda.min.css",
              "projects/site/styles/styles.scss"
            ],
            "scripts": [
              "node_modules/bootstrap/dist/js/bootstrap.min.js",
              "node_modules/moment/min/moment.min.js",
              "node_modules/sweetalert2/dist/sweetalert2.min.js"
            ]
          },
          "configurations": {
            "dev": {
              "fileReplacements": [
                {
                  "replace": "projects/site/environments/environment.ts",
                  "with": "projects/site/environments/environment.dev.ts"
                }
              ]
            },
            "uat": {
              "fileReplacements": [
                {
                  "replace": "projects/site/environments/environment.ts",
                  "with": "projects/site/environments/environment.uat.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true
            },
            "prod": {
              "fileReplacements": [
                {
                  "replace": "projects/site/environments/environment.ts",
                  "with": "projects/site/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "site:build",
            "port": 3000
          },
          "configurations": {
            "dev": {
              "browserTarget": "site:build:dev"
            },
            "uat": {
              "browserTarget": "site:build:uat"
            },
            "prod": {
              "browserTarget": "site:build:prod"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "site:build"
          }
        }
      }
    },
    "admin": {
      "root": "projects/admin/",
      "sourceRoot": "projects/admin",
      "projectType": "application",
      "prefix": "ja",
      "schematics": {
        "@schematics/angular:component": {
          "styleext": "scss"
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/admin",
            "index": "projects/admin/index.html",
            "main": "projects/admin/main.ts",
            "polyfills": "projects/admin/polyfills.ts",
            "tsConfig": "projects/admin/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "library/assets",
                "output": "/"
              },
              {
                "glob": "**/*",
                "input": "projects/admin/assets",
                "output": "/"
              }
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "projects/admin",
                "projects/admin/styles"
              ]
            },
            "styles": [
              "node_modules/@fortawesome/fontawesome-free/css/all.min.css",
              "node_modules/animate.css/animate.min.css",
              "node_modules/ladda/dist/ladda.min.css",
              "projects/admin/styles/styles.scss"
            ],
            "scripts": [
              "node_modules/bootstrap/dist/js/bootstrap.min.js",
              "node_modules/moment/min/moment.min.js",
              "node_modules/sweetalert2/dist/sweetalert2.min.js"
            ]
          },
          "configurations": {
            "dev": {
              "fileReplacements": [
                {
                  "replace": "projects/admin/environments/environment.ts",
                  "with": "projects/admin/environments/environment.dev.ts"
                }
              ]
            },
            "uat": {
              "fileReplacements": [
                {
                  "replace": "projects/admin/environments/environment.ts",
                  "with": "projects/admin/environments/environment.uat.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true
            },
            "prod": {
              "fileReplacements": [
                {
                  "replace": "projects/admin/environments/environment.ts",
                  "with": "projects/admin/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "admin:build",
            "port": 4000
          },
          "configurations": {
            "dev": {
              "browserTarget": "admin:build:dev"
            },
            "uat": {
              "browserTarget": "admin:build:uat"
            },
            "prod": {
              "browserTarget": "admin:build:prod"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "admin:build"
          }
        }
      }
    }
  },
  "defaultProject": "site"
}
